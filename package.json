{
  "name": "starglaze",
  "version": "1.0.0",
  "description": "Star Glaze — The Ultimate OG Fortnite Launcher",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.starglaze.launcher",
    "productName": "Star Glaze",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/logo.png",
      "uninstallerIcon": "assets/logo.png"
    },
    "publish": {
      "provider": "github",
      "owner": "abigailleahgoldberg",
      "repo": "starglaze"
    }
  },
  "author": "ZJ / Star Glaze",
  "license": "MIT",
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  }
}
